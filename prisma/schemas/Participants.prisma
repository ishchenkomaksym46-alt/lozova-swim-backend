model Participants {
  id           Int    @id @default(autoincrement())
  name         String
  surname      String
  heatId       Int    @map("heat_id")
  heat         Heats  @relation(fields: [heatId], references: [id])
  declaredTime String @map("declared_time")
  actualTime   String @default("No time yet") @map("actual_time")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  results   Results[]

  @@map("participants")
}
