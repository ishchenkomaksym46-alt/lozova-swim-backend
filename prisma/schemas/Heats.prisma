model Heats {
  id         Int       @id @default(autoincrement())
  heatNumber Int       @map("heat_number")
  distanceId Int       @map("distance_id")
  distance   Distances @relation(fields: [distanceId], references: [id], onDelete: Cascade)

  // Relations
  participants Participants[]
  results      Results[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("heats")
}
