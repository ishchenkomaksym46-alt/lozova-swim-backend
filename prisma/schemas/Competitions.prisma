model Competition {
  id        Int    @id @default(autoincrement())
  name      String @unique
  date      String
  laneCount Int    @default(6) @map("lane_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  distances Distances[]
  swimmers  Swimmers[]
  protocols Protocols[]

  @@map("competitions")
}
